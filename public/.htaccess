# ============================================================================
# Academia JOSEPAN 360 — public/.htaccess
# Este es el DocumentRoot. No reescribe a /public (el vhost ya apunta aquí).
# ============================================================================

# Página de entrada
DirectoryIndex index.php

# No listar directorios
Options -Indexes
Options +FollowSymLinks

# Bloquear archivos sensibles que pudieran quedar dentro del webroot
<FilesMatch "\.(sql|md|example|log|ini|lock|sh|bak)$">
    Require all denied
</FilesMatch>

# Bloquear archivos ocultos (.git, .env, .htaccess, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Cabeceras de seguridad
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Strict-Transport-Security "max-age=15552000; includeSubDomains"
</IfModule>

# Compresión de texto (opcional)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Cache de estáticos (opcional)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/svg+xml "access plus 7 days"
</IfModule>

# Forzar HTTPS solo si el SSL termina en ESTE Apache y no usas un vhost :80
# de redirección (ver la guía). Descomenta si aplica:
# <IfModule mod_rewrite.c>
#     RewriteEngine On
#     RewriteCond %{HTTPS} off
#     RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>
